{
  "name": "@calcom/chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:tunnel": "npx concurrently \"next dev\" \"cloudflared tunnel --url http://localhost:3000\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules",
    "env:check": "node -e \"const fs=require('fs');const ex=fs.readFileSync('.env.example','utf8').match(/^[A-Z_]+/gm);const lc=fs.readFileSync('.env',{encoding:'utf8',flag:'r'});const missing=ex.filter(k=>!lc.includes(k));if(missing.length){console.error('Missing env vars:',missing);process.exit(1)}else console.log('All env vars present')\"",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "deploy": "npx vercel --prod --yes"
  },
  "dependencies": {
    "@ai-sdk/groq": "3.0.29",
    "@ai-sdk/openai": "3.0.41",
    "@chat-adapter/shared": "4.19.0",
    "@chat-adapter/slack": "4.19.0",
    "@chat-adapter/state-ioredis": "4.19.0",
    "@chat-adapter/state-memory": "4.19.0",
    "@chat-adapter/state-redis": "4.19.0",
    "@chat-adapter/telegram": "4.19.0",
    "@vercel/functions": "3.4.3",
    "ai": "6.0.116",
    "chat": "4.19.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "5.11.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.19.37",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  }
}
